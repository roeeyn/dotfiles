#!/bin/bash

# tmux-taskizer: Create task-based tmux sessions
#
# Usage:
#   tmux-taskizer        → prompt for task name, use PWD, run cls (fast mode)
#   tmux-taskizer -i     → prompt for task name, pick directory, choose claude/opencode/none
#   tmux-taskizer -q     → quick prompt: ask for prompt & dir, choose claude/opencode/none
#

sanitize_name() {
  printf '%s' "$1" | tr "'.:\"\\\$#()!" '___________' | tr -s ' ' '-' | cut -c1-50
}

build_starter_command() {
  local starter="$1"
  local prompt_text="${2:-}"
  local escaped_prompt

  case "$starter" in
    claude)
      if [ -n "$prompt_text" ]; then
        escaped_prompt=$(printf '%s' "$prompt_text" | sed "s/'/'\\\\''/g")
        printf "cls '%s'" "$escaped_prompt"
      else
        printf 'cls'
      fi
      ;;
    opencode)
      if [ -n "$prompt_text" ]; then
        escaped_prompt=$(printf '%s' "$prompt_text" | sed "s/'/'\\\\''/g")
        printf "oc --prompt '%s'" "$escaped_prompt"
      else
        printf 'oc'
      fi
      ;;
    none)
      printf ''
      ;;
  esac
}

interactive=false
quick_prompt=false

while getopts "iq" opt; do
  case $opt in
    i)
      interactive=true
      ;;
    q)
      quick_prompt=true
      ;;
  esac
done

# --- Quick Prompt mode ---
if [ "$quick_prompt" = true ]; then
  read -rp "Prompt: " prompt_text

  if [ -z "$prompt_text" ]; then
    echo "No prompt provided, aborting."
    exit 1
  fi

  session_name=$(sanitize_name "$prompt_text")

  # If session already exists, just switch to it
  if tmux has-session -t="$session_name" 2>/dev/null; then
    if [ -z "$TMUX" ]; then
      tmux attach -t "$session_name"
    else
      tmux switch-client -t "$session_name"
    fi
    exit 0
  fi

  # Pick working directory (default: PWD)
  selected=$({ echo "$PWD"; find ~ ~/src ~/playground ~/Desktop /Users/roeeyn/Library/CloudStorage/OneDrive-AlertMedia/Desktop -mindepth 1 -maxdepth 1 -type d 2>/dev/null; } | fzf --prompt="Directory (default PWD): " --header="Press ESC to use $PWD")
  work_dir="${selected:-$PWD}"

  selected_starter=$(printf '%s\n' 'claude' 'opencode' 'none' | fzf --prompt="Starter: " --header="ESC defaults to claude")
  starter_command=$(build_starter_command "${selected_starter:-claude}" "$prompt_text")

  # Create session and optionally start the selected tool with the prompt
  tmux new-session -d -s "$session_name" -n "quick" -c "$work_dir"

  if [ -n "$starter_command" ]; then
    tmux send-keys -t "$session_name:quick" "$starter_command" C-m
  fi

  if [ -z "$TMUX" ]; then
    tmux attach -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
  exit 0
fi

# --- Normal mode ---

# Prompt for task/ticket name
read -rp "Task name: " task_name

if [ -z "$task_name" ]; then
  echo "No task name provided, aborting."
  exit 1
fi

session_name=$(sanitize_name "$task_name")

# If session already exists, just switch to it
if tmux has-session -t="$session_name" 2>/dev/null; then
  if [ -z "$TMUX" ]; then
    tmux attach -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
  exit 0
fi

# Defaults
work_dir="$PWD"
starter_command=$(build_starter_command claude)

if [ "$interactive" = true ]; then
  # Pick working directory via fzf, with PWD as the first option
  selected=$({ echo "$PWD"; find ~ ~/src ~/playground ~/Desktop /Users/roeeyn/Library/CloudStorage/OneDrive-AlertMedia/Desktop -mindepth 1 -maxdepth 1 -type d 2>/dev/null; } | fzf --prompt="Directory: ")
  if [ -z "$selected" ]; then
    echo "No directory selected, aborting."
    exit 1
  fi
  work_dir="$selected"

  selected_starter=$(printf '%s\n' 'claude' 'opencode' 'none' | fzf --prompt="Starter: " --header="ESC defaults to claude")
  starter_command=$(build_starter_command "${selected_starter:-claude}")
fi

# Create session with "main convo" window
tmux new-session -d -s "$session_name" -n "main convo" -c "$work_dir"

# Run selected starter in the main window
if [ -n "$starter_command" ]; then
  tmux send-keys -t "$session_name:main convo" "$starter_command" C-m
fi

# Switch to the new session
if [ -z "$TMUX" ]; then
  tmux attach -t "$session_name"
else
  tmux switch-client -t "$session_name"
fi
