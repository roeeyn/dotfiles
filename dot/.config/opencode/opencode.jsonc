{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--isolated"]
    },
    "bitbucket": {
      "type": "local",
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "environment": {
        "ATLASSIAN_SITE_NAME": "bitbucket",
        "ATLASSIAN_USER_EMAIL": "{env:ATLASSIAN_USERNAME}",
        "ATLASSIAN_API_TOKEN": "{env:BITBUCKET_API_KEY}"
      }
    },
    "mcp-atlassian": {
      "type": "local",
      "command": ["uvx", "mcp-atlassian"],
      "environment": {
        "JIRA_URL": "{env:ATLASSIAN_URL}",
        "JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "JIRA_API_TOKEN": "{env:ATLASSIAN_API_KEY}",
        "CONFLUENCE_URL": "{env:ATLASSIAN_URL}/wiki",
        "CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_API_KEY}"
      }
    },
  }
}
